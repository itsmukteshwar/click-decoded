# ─────────────────────────────────────────────
# Click Decoded — Environment Variables
# Copy this file to .env.local and fill values
# NEVER commit .env.local to git
# ─────────────────────────────────────────────

# Resend (email service) — get key at resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Email where contact form submissions go
CONTACT_TO_EMAIL=hello@clickdecoded.com

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://clickdecoded.com

# WhatsApp number (country code + number, no + or spaces)
NEXT_PUBLIC_WA_NUMBER=919407000101

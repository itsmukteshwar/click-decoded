{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/gtag/js",
      "destination": "https://www.googletagmanager.com/gtag/js"
    },
    {
      "source": "/g/collect",
      "destination": "https://www.google-analytics.com/g/collect"
    },
    {
      "source": "/analytics/collect",
      "destination": "https://www.google-analytics.com/g/collect"
    }
  ]
}